# Rename this file to .env and fill in the values below.
# Used by docker-compose.yml, the AI agent, and local (non-Docker) Cypress runs.

# ---------------------------------------------------------------------------
# AI agent (ai-agent/) — spec generation and failure diagnosis
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# ---------------------------------------------------------------------------
# Cypress AI — required only to run the ai-driven/ specs using cy.prompt
# ---------------------------------------------------------------------------
CYPRESS_AI_KEY=<YOUR_CYPRESS_AI_KEY>

# ---------------------------------------------------------------------------
# Redis — connection string used by both the app-under-test service and the
# AI agent's LLM response cache (see ai-agent/cache.py). The docker-compose
# default below works out of the box when running the full stack via
# `docker compose up`; override only for local/non-Docker setups.
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# App under test — overridden automatically to http://app:3000 / :3001
# inside docker-compose; only needed here for local (non-Docker) runs.
# ---------------------------------------------------------------------------
CYPRESS_BASE_URL=http://localhost:3000
CYPRESS_API_URL=http://localhost:3001
